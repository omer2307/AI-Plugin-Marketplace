{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "marketplace.schema.json",
  "title": "Claude Code Plugin Marketplace",
  "description": "Schema for .claude-plugin/marketplace.json",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference URL"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 3,
      "maxLength": 50,
      "description": "Marketplace identifier (kebab-case)",
      "errorMessage": "name must be 3-50 lowercase alphanumeric characters with hyphens, starting with a letter"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version for forward compatibility"
    },
    "description": {
      "type": "string",
      "description": "Brief marketplace description"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      },
      "errorMessage": {
        "required": {
          "name": "owner.name is required"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "pluginRoot": {
          "type": "string"
        }
      },
      "additionalProperties": true,
      "description": "Optional metadata object for future extension fields"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginEntry"
      },
      "description": "List of available plugins"
    }
  },
  "$defs": {
    "pluginEntry": {
      "type": "object",
      "required": ["name", "source"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 3,
          "maxLength": 50,
          "errorMessage": "plugin name must be 3-50 lowercase alphanumeric characters with hyphens"
        },
        "source": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^\\.\\/"
            },
            {
              "$ref": "#/$defs/githubSource"
            },
            {
              "$ref": "#/$defs/urlSource"
            },
            {
              "$ref": "#/$defs/sshSource"
            }
          ],
          "errorMessage": "source must be a relative path (./...), a GitHub source object, a URL source object, or an SSH source object"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "author": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "email": {
              "type": "string",
              "format": "email"
            }
          }
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "repository": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "category": {
          "type": "string",
          "description": "Plugin category for organization"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for searchability"
        },
        "strict": {
          "type": "boolean"
        },
        "commands": {},
        "agents": {},
        "hooks": {},
        "mcpServers": {},
        "lspServers": {},
        "skills": {},
        "outputStyles": {}
      }
    },
    "githubSource": {
      "type": "object",
      "required": ["source", "repo"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "const": "github"
        },
        "repo": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+$",
          "errorMessage": "repo must be in owner/repo format"
        },
        "ref": {
          "type": "string"
        },
        "sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$",
          "errorMessage": "sha must be a full 40-character git commit hash"
        }
      }
    },
    "urlSource": {
      "type": "object",
      "required": ["source", "url"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "const": "url"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "\\.git$",
          "errorMessage": "url must be a valid git repository URL ending in .git"
        },
        "ref": {
          "type": "string"
        },
        "sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        }
      }
    },
    "sshSource": {
      "type": "object",
      "required": ["source", "url"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "const": "ssh"
        },
        "url": {
          "type": "string",
          "pattern": "^git@[a-zA-Z0-9._-]+:[a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+\\.git$",
          "errorMessage": "url must be an SSH git URL in git@host:owner/repo.git format"
        },
        "ref": {
          "type": "string"
        },
        "sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        }
      }
    }
  }
}
